# .dockerignore dosyasını düzelt
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.git
.gitignore
README.md

# Test coverage output
server/coverage/

# Bicep compiled ARM output (source of truth is .bicep files)
infra/*.json

# Terraform state & secrets (never commit these)
infra/aws/.terraform/
infra/aws/.terraform.lock.hcl
infra/aws/*.tfstate
infra/aws/*.tfstate.backup
infra/aws/*.tfvars
infra/aws/crash.log
infra/aws/override.tf
infra/aws/override.tf.json

# Trigger.dev build cache
server/.trigger/