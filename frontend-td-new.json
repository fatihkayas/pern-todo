{
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::576418249619:role/seiko-ecs-task-execution-role",
  "family": "seiko-frontend",
  "memory": "512",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "containerDefinitions": [
    {
      "name": "frontend",
      "image": "576418249619.dkr.ecr.eu-central-1.amazonaws.com/seiko-frontend:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "BROWSER",
          "value": "none"
        },
        {
          "name": "DANGEROUSLY_DISABLE_HOST_CHECK",
          "value": "true"
        },
        {
          "name": "REACT_APP_STRIPE_PUBLISHABLE_KEY",
          "value": "pk_test_51SWOd7DWjwrv17wW0wQvhKqSCerOSLTuULGwOTtZ3edEjfFacU4ZSDZ7XpP23s0Wx8ykSxA3LSDDdgDBMBWoZDSg00aRSPHRPy"
        },
        {
          "name": "REACT_APP_STRIPE_PUBLISHABLE_KEY",
          "value": "pk_test_51SWOd7DWjwrv17wW0wQvhKqSCerOSLTuULGwOTtZ3edEjfFacU4ZSDZ7XpP23s0Wx8ykSxA3LSDDdgDBMBWoZDSg00aRSPHRPy"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/seiko-frontend",
          "awslogs-region": "eu-central-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "systemControls": []
    }
  ],
  "cpu": "256"
}
