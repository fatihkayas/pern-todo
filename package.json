{
  "name": "seiko-watch-store",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "concurrently --kill-others --names \"server,client\" --prefix-colors \"cyan,green\" \"cd server && npm run dev\" \"cd client && npm start\""
  },
  "dependencies": {
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2"
  },
  "lint-staged": {
    "server/**/*.ts": [
      "bash -c 'cd server && npx eslint --fix \"$@\"' --",
      "bash -c 'cd server && npx prettier --write \"$@\"' --"
    ]
  }
}
