{
  "title": "Pizza & Doner Backend",
  "uid": "pizza-backend",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
  "panels": [
    {
      "id": 1,
      "title": "Pizza/Doner Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{route=~\"/api/v1/pizza.*\"}[1m])) by (route,method)",
          "legendFormat": "{{method}} {{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 } }
    },
    {
      "id": 2,
      "title": "Pizza/Doner Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{route=~\"/api/v1/pizza.*\",status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{route=~\"/api/v1/pizza.*\"}[5m])), 1)",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 3,
      "title": "Pizza/Doner P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket{route=~\"/api/v1/pizza.*\"}[5m])) by (le,route))",
          "legendFormat": "p95 {{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "min": 0 } }
    },
    {
      "id": 4,
      "title": "Catalog Loads / s",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{method=\"GET\",route=~\"/api/v1/pizza|/api/v1/pizza/:id\"}[1m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 } }
    },
    {
      "id": 5,
      "title": "Orders Created",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "orders_created_total",
          "legendFormat": "orders"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 6,
      "title": "Revenue ($)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "orders_revenue_dollars_total",
          "legendFormat": "revenue"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 7,
      "title": "Checkout Requests / s",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{route=\"/api/v1/pizza/orders\",method=\"POST\"}[1m]))",
          "legendFormat": "site checkout"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 } }
    },
    {
      "id": 8,
      "title": "Kafka Events Consumed / s (orders.created)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(integration_events_consumed_total{topic=\"orders.created\"}[1m]))",
          "legendFormat": "orders.created"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "min": 0 } }
    },
    {
      "id": 9,
      "title": "Kafka Failures / s (orders.created)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(integration_events_failed_total{topic=\"orders.created\"}[1m]))",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "id": 10,
      "title": "Kafka Retry / DLQ (orders.created)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(integration_events_retried_total{topic=\"orders.created\"}[1m]))",
          "legendFormat": "retry"
        },
        {
          "expr": "sum(rate(integration_events_dlq_total{topic=\"orders.created\"}[1m]))",
          "legendFormat": "dlq"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "min": 0 } }
    },
    {
      "id": 11,
      "title": "Node.js Heap Used (MB)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes / 1024 / 1024",
          "legendFormat": "heap MB"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decbytes", "min": 0 } }
    },
    {
      "id": 12,
      "title": "Event Loop Lag (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds * 1000",
          "legendFormat": "lag ms"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "min": 0 } }
    }
  ]
}
