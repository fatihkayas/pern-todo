{
  "title": "Integration Service",
  "uid": "seiko-integration",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
  "panels": [
    {
      "id": 1,
      "title": "Events Consumed / s",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(integration_events_consumed_total[1m])) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "min": 0 }
      }
    },
    {
      "id": 2,
      "title": "Events Failed / s",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(integration_events_failed_total[1m])) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "min": 0, "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 3,
      "title": "Success Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "100 - (100 * sum(rate(integration_events_failed_total[5m])) / sum(rate(integration_events_consumed_total[5m])))",
          "legendFormat": "success %"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Processing Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "histogram_quantile(0.50, sum(rate(integration_event_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "histogram_quantile(0.95, sum(rate(integration_event_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "histogram_quantile(0.99, sum(rate(integration_event_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 }
      }
    },
    {
      "id": 5,
      "title": "Retry Rate / s",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(integration_events_retried_total[1m])) by (topic)",
          "legendFormat": "retries — {{topic}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(integration_events_dlq_total[1m])) by (topic)",
          "legendFormat": "DLQ — {{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "min": 0 }
      }
    },
    {
      "id": 6,
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "integration_circuit_breaker_state{name=\"servicenow\"}",
          "legendFormat": "servicenow"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "OPEN", "color": "red" }, "2": { "text": "HALF-OPEN", "color": "yellow" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 7,
      "title": "Total Consumed",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(integration_events_consumed_total)",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "blue", "mode": "fixed" } }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 8,
      "title": "Total Failed",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(integration_events_failed_total)",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "red", "mode": "fixed" } }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 9,
      "title": "Total DLQ",
      "type": "stat",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "expr": "sum(integration_events_dlq_total)",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "orange", "mode": "fixed" } }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ]
}
